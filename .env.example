# CORE APP CONFIG
APP_NAME=Candid API
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173

# LLM CONFIG (REQUIRED — app will not start without a non-empty key)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
# Max output tokens per reply (256–64000; default 8192 for long prompts + room to answer)
CLAUDE_MAX_OUTPUT_TOKENS=8192

# STORAGE / RETRIEVAL
CHROMA_PERSIST_DIR=./data/chroma

# REDDIT (public JSON; optional tuning)
REDDIT_USER_AGENT=CandidBot/0.1 (+https://example.com)
REDDIT_TIMEOUT_SECONDS=20

# TIER 1B TRUSTED APIs (optional — Tier 1B runs only when static KB has no match for the topic)
ENABLE_TRUSTED_API_FETCH=true
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html — enables US macro corroboration with World Bank
FRED_API_KEY=
# UN Population Data Portal: Bearer token for /data/* (https://population.un.org/dataportal/); optional
UN_DATAPORTAL_BEARER_TOKEN=

# SAFETY
ENABLE_SAFETY_FILTER=true

# CHAT API (send in JSON body to POST /api/v1/chat, not as env vars):
# turn_index, history, topic, source_query — see backend/README.md
