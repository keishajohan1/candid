# CORE APP CONFIG
APP_NAME=Candid API
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173

# LLM CONFIG (REQUIRED FOR CHAT)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# STORAGE / RETRIEVAL
CHROMA_PERSIST_DIR=./data/chroma

# SCRAPING / INGESTION
TIKTOK_HEADLESS=true
TIKTOK_LOCALE=en-US
TIKTOK_TIMEOUT_SECONDS=20
TIKTOK_WAIT_MS=2500
TIKTOK_USER_AGENT=
TIKTOK_SESSION_COOKIE=
TIKTOK_PROXY_URL=
PLAYWRIGHT_BROWSERS_PATH=
REDDIT_USER_AGENT=CandidBot/0.1 (+https://example.com)
REDDIT_TIMEOUT_SECONDS=20

# SAFETY
ENABLE_SAFETY_FILTER=true
